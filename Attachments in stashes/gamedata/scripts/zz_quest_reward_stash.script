--[[
================================================================================
  Attachments in stashes Mod (zz_quest_reward_stash)

  Funkcionalumas:
  1. Traderiai NEBEPARDUODA attachment'ų (scope, silencer, weapon/armor upgr-kit'ai) (Traders dont sell attachments)
  2. Kas 10-12 questų atsiranda TAMSIAI MĖLYNAS stash'as ("quest_reward_stash") (every 10-12 quests, a dark blue stash appears)
     - Turinys: attachment'ai (loot kaip baltas stash) (contains white stash loot + attachments)
  3. Kas 20-25 questų atsiranda ŠVIESIAI MĖLYNAS stash'as ("quest_reward_stash_rare") (every 20-25 quest, a light blue stash appears)
     - Turinys: attachment'ai + kit'as (+ tool kit) (contains white stash loot + gun kit + attachments + tool kit)
  4. Attachment'ų kokybė priklauso nuo žemėlapio tier'o (Attachments depend on map)
  5. Žemėlapio tier'ai: (map tiers)
      PRASTI  (tier 1-2): cordon, great_swamps, garbage, darkvalley, darkscape, meadows (Bad tier 1-2)
      VIDUTINIAI (tier 2-3): rostok, agroprom, truck_cemetery, deadcity, army warehouses, radar (Medium tier 2-3)
      GERIAUSI  (tier 3-5): visi kiti (yantar, jupiter, red forest, pripyat, ir kt.) (Best tier 3-5)
================================================================================
--]]

local QRS_VERSION = "1.2.2"

-- ============================================================================
-- NUSTATYMŲ KONFIGŪRACIJA (settings) (Naudoja MCM jei įdiegta) (if MCM present)
-- ============================================================================
local function get_config(key, default)
    if ui_mcm then
        local val = ui_mcm.get("qrs/" .. key)
        if val ~= nil then return val end
    end
    return default
end

local function get_quests_attach_min() return get_config("attach_min", 10) end
local function get_quests_attach_max() return get_config("attach_max", 12) end
local function get_quests_kit_min()    return get_config("kit_min", 20) end
local function get_quests_kit_max()    return get_config("kit_max", 25) end
local function get_allow_t1_trader()   return get_config("trader_t1", false) end
local function get_replace_quest_stash() return get_config("replace_quest_stash", true) end

_G.QRS_BLOCK_NEXT_STASH = false

